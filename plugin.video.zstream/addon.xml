<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.zstream" name="zStream" version="1.0.5" provider-name="zStream Team">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.22.0"/>
        <import addon="script.module.routing" version="0.2.0"/>
        <import addon="script.module.beautifulsoup4" version="4.6.2"/>
        <import addon="script.module.six"/>
        <import addon="script.module.kodi-six"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">zStream - The best way to watch s.to, aniworld.to and movie2k.ch</summary>
        <description lang="en">zStream is a video addon for s.to, aniworld.to and movie2k.ch.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
